# ── Storage ───────────────────────────────────────────────────────────────────
# Where uploaded videos, clips, and the SQLite database are stored.
# Defaults to ./storage if not set.
STORAGE_ROOT=./storage

# ── Local AI (oMLX) ───────────────────────────────────────────────────────────
# URL of a local OpenAI-compatible inference server.
OMLX_URL=http://localhost:8000
OMLX_MODEL=mlx-community/Llama-3.3-70B-Instruct-4bit
OMLX_API_KEY=

# ── Claude (Anthropic) ────────────────────────────────────────────────────────
# Used when AI Model is set to Claude in Settings.
# Can also be pasted directly in the Settings page.
ANTHROPIC_API_KEY=

# ── YouTube ───────────────────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ── TikTok ────────────────────────────────────────────────────────────────────
# Set TIKTOK_ENV to "sandbox" for testing or "production" for live publishing.
TIKTOK_ENV=sandbox
TIKTOK_CLIENT_KEY_SANDBOX=
TIKTOK_CLIENT_SECRET_SANDBOX=
TIKTOK_CLIENT_KEY_PRODUCTION=
TIKTOK_CLIENT_SECRET_PRODUCTION=

# ── Instagram ─────────────────────────────────────────────────────────────────
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
# Instagram fetches your video from a public URL — expose your local server
# with a tunnel (e.g. ngrok) and set the URL here.
APP_PUBLIC_URL=

# ── Twitter / X ───────────────────────────────────────────────────────────────
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
